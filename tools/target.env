# Per-device QNN target switch. Source before convert/quantize/context-binary:
#   TARGET_DEVICE=s22plus source tools/target.env
# Read SOC_ID / PLATFORM / HTP_ARCH off the ACTUAL S26 unit before pinning it
# (doc/project_draft marks the Elite Gen 5 values TBD).

case "${TARGET_DEVICE}" in
  s22plus)   HTP_ARCH=v69 ; SOC_ID=36 ; PLATFORM=taro  ;;  # SM8450 (confirmed; soc_id 36, on-device)
  s26ultra)  HTP_ARCH=v8x ; SOC_ID=TBD ; PLATFORM=canoe ;;  # SM-S948W / SM8850 (8 Elite Gen 5),
              # confirmed on-device. HTP arch is NEWER than v75 -> NOT supported by QAIRT 2.26.2
              # (lib/hexagon-v66..v75 only). Needs QAIRT >= 2.47 to read the arch + build the
              # context binary. Until then the S26 falls back to the ORT/CPU path.
  *) echo "unknown TARGET_DEVICE: '${TARGET_DEVICE}' (use s22plus|s26ultra)" >&2 ; return 1 2>/dev/null || exit 1 ;;
esac
export TARGET_DEVICE HTP_ARCH SOC_ID PLATFORM
echo "target=${TARGET_DEVICE} htp_arch=${HTP_ARCH} soc_id=${SOC_ID} platform=${PLATFORM}"
