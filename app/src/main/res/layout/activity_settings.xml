<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:padding="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView style="@style/SettingsSection" android:text="Alerts" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/audible" style="@style/SettingsSwitch" android:text="@string/pref_audible" />
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/haptic" style="@style/SettingsSwitch" android:text="@string/pref_haptic" />
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/hud" style="@style/SettingsSwitch" android:text="@string/pref_hud" />

        <TextView style="@style/SettingsSection" android:text="Warning functions" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/fcw" style="@style/SettingsSwitch" android:text="@string/pref_fcw" />
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/ldw" style="@style/SettingsSwitch" android:text="@string/pref_ldw" />
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/headway" style="@style/SettingsSwitch" android:text="@string/pref_headway" />
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/tsr" style="@style/SettingsSwitch" android:text="@string/pref_tsr" />

        <TextView style="@style/SettingsSection" android:text="@string/settings_validation" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/replay" style="@style/SettingsSwitch" android:text="@string/pref_replay" />
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:lineSpacingMultiplier="1.25"
            android:text="@string/pref_replay_hint"
            android:textColor="@color/text_muted" android:textSize="13sp" />

        <TextView style="@style/SettingsSection" android:text="@string/disclaimer_review" />
        <TextView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.25" android:text="@string/disclaimer_body"
            android:textColor="@color/text_muted" android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
