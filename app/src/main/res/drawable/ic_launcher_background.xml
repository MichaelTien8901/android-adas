<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon background: deep-navy vertical gradient (brand palette) with a faint
     perspective road wedge for depth. 108x108 canvas. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="0"
                android:endX="54" android:endY="108"
                android:startColor="#16314C"
                android:endColor="#0A1622" />
        </aapt:attr>
    </path>

    <!-- Subtle road wedge (perspective) toward the horizon, low-contrast. -->
    <path
        android:pathData="M42,96 L66,96 L59,46 L49,46 Z"
        android:fillColor="#1E3F5F"
        android:fillAlpha="0.5" />
</vector>
