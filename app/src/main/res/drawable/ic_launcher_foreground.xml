<!-- ADAS mark: a bat-cowl gestalt built from ADAS cues — the pointed "ears" are detected
     lane lines (cyan, dashed centre) and the "eyes" are two Beetle cars; red traffic signs
     flank the sides (TSR). Original mark (not DC's trademarked bat emblem). Over the dark
     blue gradient background. 108 canvas. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Faint cowl silhouette (holds the gestalt). -->
    <path
        android:pathData="M39,17 L49,44 L54,37 L59,44 L69,17 L72,52 L70,68 L64,80 L54,85 L44,80 L38,68 L36,52 Z"
        android:fillColor="#0C162C" android:fillAlpha="0.7"
        android:strokeColor="#21426E" android:strokeWidth="1" />

    <!-- Ears as detected lane lines (cyan) converging upward. -->
    <path android:pathData="M36,46 L40,16" android:strokeColor="#46D8FF" android:strokeWidth="2.6" android:strokeLineCap="round" />
    <path android:pathData="M48,44 L40,16" android:strokeColor="#46D8FF" android:strokeWidth="2.6" android:strokeLineCap="round" />
    <path android:pathData="M72,46 L68,16" android:strokeColor="#46D8FF" android:strokeWidth="2.6" android:strokeLineCap="round" />
    <path android:pathData="M60,44 L68,16" android:strokeColor="#46D8FF" android:strokeWidth="2.6" android:strokeLineCap="round" />

    <!-- Dashed centre markings up each lane. -->
    <path android:fillColor="#F2F8FC" android:pathData="M41.3,38 h1.4 v4 h-1.4 z M40.3,31 h1.4 v4 h-1.4 z M39.3,24 h1.4 v4 h-1.4 z" />
    <path android:fillColor="#F2F8FC" android:pathData="M65.3,38 h1.4 v4 h-1.4 z M66.3,31 h1.4 v4 h-1.4 z M67.3,24 h1.4 v4 h-1.4 z" />

    <!-- Eyes as Beetle cars (domed body + window + wheels). -->
    <path android:fillColor="#F2F8FC" android:pathData="M41,59 A6,6 0 0 1 53,59 L53,61 L41,61 Z" />
    <path android:fillColor="#46D8FF" android:pathData="M44.8,57.5 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0 Z" />
    <path android:fillColor="#0C162C" android:pathData="M42.1,61.2 a1.7,1.7 0 1,0 3.4,0 a1.7,1.7 0 1,0 -3.4,0 Z M48.5,61.2 a1.7,1.7 0 1,0 3.4,0 a1.7,1.7 0 1,0 -3.4,0 Z" />

    <path android:fillColor="#F2F8FC" android:pathData="M55,59 A6,6 0 0 1 67,59 L67,61 L55,61 Z" />
    <path android:fillColor="#46D8FF" android:pathData="M58.8,57.5 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0 Z" />
    <path android:fillColor="#0C162C" android:pathData="M56.1,61.2 a1.7,1.7 0 1,0 3.4,0 a1.7,1.7 0 1,0 -3.4,0 Z M62.5,61.2 a1.7,1.7 0 1,0 3.4,0 a1.7,1.7 0 1,0 -3.4,0 Z" />

