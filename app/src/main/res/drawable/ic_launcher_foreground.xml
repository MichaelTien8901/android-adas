<?xml version="1.0" encoding="utf-8"?>
<!-- ADAS "dark guardian" cowl: an original bat-style mask (pointed ears, angular eyes) that
     leans into the look while staying an original mark (not DC's trademarked bat emblem).
     The eyes glow cyan like vision sensors, tying it to the ADAS perception theme.
     Sits over the dark blue gradient background. 108 canvas. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Cowl silhouette: two pointed ears, brow V, rounded jaw. -->
    <path
        android:pathData="M39,17 L49,44 L54,37 L59,44 L69,17 L72,52 L70,68 L64,80 L54,85 L44,80 L38,68 L36,52 Z"
        android:fillColor="#0E1933"
        android:strokeColor="#2E5FA6"
        android:strokeWidth="1" />

    <!-- Brow shadow (depth between the ears). -->
    <path
        android:pathData="M39,17 L49,44 L54,39 L59,44 L69,17 L60,41 L54,46 L48,41 Z"
        android:fillColor="#080F20" />

    <!-- Glowing cyan sensor-eyes (angled). -->
    <path android:pathData="M42,60 L52,54 L52.5,59 L42.5,65 Z"
        android:fillColor="#46D8FF" android:strokeColor="#CBF2FF" android:strokeWidth="0.6" />
    <path android:pathData="M66,60 L56,54 L55.5,59 L65.5,65 Z"
        android:fillColor="#46D8FF" android:strokeColor="#CBF2FF" android:strokeWidth="0.6" />
</vector>
